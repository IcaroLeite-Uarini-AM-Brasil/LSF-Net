# LSF-Net Environment Variables

# Flask Configuration
FLASK_ENV=development
FLASK_APP=app.py
DEBUG=True

# Server
PORT=5000
HOST=0.0.0.0

# Database (future use)
DATABASE_URL=sqlite:///lsfnet.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
CORS_ORIGINS=http://localhost:5000,http://localhost:3000

# Logging
LOG_LEVEL=INFO
